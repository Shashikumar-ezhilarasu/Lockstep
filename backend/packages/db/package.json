{
  "name": "db",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "db:push": "npx dotenv-cli -e ../../.env -- drizzle-kit push:pg",
    "db:generate": "npx dotenv-cli -e ../../.env -- drizzle-kit generate",
    "db:studio": "npx dotenv-cli -e ../../.env -- drizzle-kit studio",
    "seed": "npx dotenv-cli -e ../../.env -- tsx src/seed.ts",
    "test": "npx dotenv-cli -e ../../.env -- vitest run"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.0",
    "pg": "^8.22.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "drizzle-kit": "^0.20.14",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5",
    "vitest": "^1.3.1"
  }
}
